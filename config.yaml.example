server:
  port: 8080
  debug: false
  reload: false

database:
  driver: mysql+aiomysql
  host: localhost
  port: 3306
  username: root
  password: password
  database: ai_gateway
  pool_size: 10
  max_overflow: 20

redis:
  host: localhost
  port: 6379
  db: 0
  password: ""
  decode_responses: true

clickhouse:
  host: localhost
  port: 8123
  database: ai_gateway
  username: default
  password: ""

jwt:
  secret: "your-secret-key-change-this-in-production"
  algorithm: "HS256"
  expires_in: 86400

audit:
  off_hours_start: 22
  off_hours_end: 6
  token_threshold_hourly: 100000
  suspicious_ip_list: []
  
default_quota:
  daily_limit: 100000
  weekly_limit: 500000
  monthly_limit: 2000000

rate_limit:
  requests_per_minute: 60

llm:
  default_timeout: 60
  max_retries: 3
